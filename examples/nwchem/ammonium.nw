start ammonium
title "ammonium opt+freq (B3LYP/6-31g*)"
echo

geometry units angstrom
  N  0.000000  0.000000  0.000000
  H  0.588897  0.588897  0.588897
  H  0.588897  -0.588897  -0.588897
  H  -0.588897  0.588897  -0.588897
  H  -0.588897  -0.588897  0.588897
end

charge 1

basis
  * library 6-31g*
end

dft
  xc b3lyp
  grid xfine
end

driver
  maxiter 200
end

task dft optimize
task dft freq
