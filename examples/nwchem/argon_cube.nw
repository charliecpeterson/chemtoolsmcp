start argon_cube
title "argon_cube opt+freq (B3LYP/6-31g*)"
echo

geometry units angstrom
  Ar  0.000000  0.000000  0.000000
  Ar  0.000000  0.000000  3.800000
  Ar  0.000000  3.800000  0.000000
  Ar  0.000000  3.800000  3.800000
  Ar  3.800000  0.000000  0.000000
  Ar  3.800000  0.000000  3.800000
  Ar  3.800000  3.800000  0.000000
  Ar  3.800000  3.800000  3.800000
end

charge 0

basis
  * library 6-31g*
end

dft
  xc b3lyp
  grid xfine
end

driver
  maxiter 200
end

task dft optimize
task dft freq
