 argument  1 = ethanol.nw
 


============================== echo of input deck ==============================
start ethanol
title "ethanol opt+freq (B3LYP/6-31g*)"
echo

geometry units angstrom
  C  0.000000  0.000000  0.000000
  C  1.530000  0.000000  0.000000
  O  2.860000  0.000000  0.000000
  H -0.540000  0.940000  0.000000
  H -0.540000 -0.470000  0.810000
  H -0.540000 -0.470000 -0.810000
  H  1.940000 -0.470000  0.810000
  H  1.940000 -0.470000 -0.810000
  H  3.370000  0.000000  0.810000
end

charge 0

basis
  * library 6-31g*
end

dft
  xc b3lyp
  grid xfine
end

driver
