start carbon_dioxide
title "carbon_dioxide opt+freq (B3LYP/6-31g*)"
echo

geometry units angstrom
  O  -1.160000  0.000000  0.000000
  C  0.000000  0.000000  0.000000
  O  1.160000  0.000000  0.000000
end

charge 0

basis
  * library 6-31g*
end

dft
  xc b3lyp
  grid xfine
end

driver
  maxiter 200
end

task dft optimize
task dft freq
