start ferrocene_frag_guess
title "Ferrocene via fragment MOs: Fe only -> Cp rings -> full complex"

memory total 2000 mb

# --- Geometry blocks (Angstrom) ---
geometry fe_only units angstrom
  Fe   0.000000   0.000000   0.000000
end

# Two cyclopentadienyl (Cp) rings placed at z=±1.65 Å, Fe not included here
# (Coordinates approximate; feel free to replace with your preferred Cp geometry.)
geometry cp2 units angstrom
  # Ring at  z = +1.65 Å
  C    1.250000   0.000000   1.650000
  C    0.386271   1.188821   1.650000
  C   -1.011271   0.734732   1.650000
  C   -1.011271  -0.734732   1.650000
  C    0.386271  -1.188821   1.650000
  H    2.350000   0.000000   1.650000
  H    0.726190   2.234983   1.650000
  H   -1.901190   1.381295   1.650000
  H   -1.901190  -1.381295   1.650000
  H    0.726190  -2.234983   1.650000

  # Ring at  z = -1.65 Å
  C    1.250000   0.000000  -1.650000
  C    0.386271   1.188821  -1.650000
  C   -1.011271   0.734732  -1.650000
  C   -1.011271  -0.734732  -1.650000
  C    0.386271  -1.188821  -1.650000
  H    2.350000   0.000000  -1.650000
  H    0.726190   2.234983  -1.650000
  H   -1.901190   1.381295  -1.650000
  H   -1.901190  -1.381295  -1.650000
  H    0.726190  -2.234983  -1.650000
end

# Full ferrocene: atoms grouped by fragment (Fe first, then both rings)
geometry full_fc units angstrom
  # Fragment 1: Fe (single atom)
  Fe   0.000000   0.000000   0.000000

  # Fragment 2: both Cp rings (same order/coords as 'cp2')
  C    1.250000   0.000000   1.650000
  C    0.386271   1.188821   1.650000
  C   -1.011271   0.734732   1.650000
  C   -1.011271  -0.734732   1.650000
  C    0.386271  -1.188821   1.650000
  H    2.350000   0.000000   1.650000
  H    0.726190   2.234983   1.650000
  H   -1.901190   1.381295   1.650000
  H   -1.901190  -1.381295   1.650000
  H    0.726190  -2.234983   1.650000

  C    1.250000   0.000000  -1.650000
  C    0.386271   1.188821  -1.650000
  C   -1.011271   0.734732  -1.650000
  C   -1.011271  -0.734732  -1.650000
  C    0.386271  -1.188821  -1.650000
  H    2.350000   0.000000  -1.650000
  H    0.726190   2.234983  -1.650000
  H   -1.901190   1.381295  -1.650000
  H   -1.901190  -1.381295  -1.650000
  H    0.726190  -2.234983  -1.650000
end

# --- One consistent basis for all atoms (must match across all stages) ---
basis "ao basis" spherical
  Fe library def2-svp
  C  library def2-svp
  H  library def2-svp
end

# --- Common DFT settings (edit to taste) ---
set tol2e 1e-8
dft
  xc b3lyp
  mult 1           # full ferrocene is closed-shell; adjust if you want spin-polarized fragments
  grid xfine       # cost-effective default; tighten if needed
  direct
  iterations 200
end

# =========================
# 1) Fe-only single point
# =========================
set geometry fe_only
charge 2            # model Fe(II) fragment; adjust if you prefer a neutral Fe atom
dft
  vectors input atomic output fe_only.movecs
end
task dft energy     # single-point DFT on Fe

# =========================
# 2) Rings-only single point
# =========================
set geometry cp2
charge -2           # two Cp- rings as an anion pair; set to 0 if you prefer neutral benzene-like rings
dft
  vectors input atomic output cp2.movecs
end
task dft energy     # single-point DFT on Cp fragments

# ==========================================
# 3) Full ferrocene: fragment-guess + OPT
# ==========================================
set geometry full_fc
charge 0
dft
  # Build initial guess by superposing the two fragment MO files.
  # IMPORTANT: Atom ordering in 'full_fc' groups Fe first, then the rings,
  # matching the order of the two files below.
  vectors input fragment fe_only.movecs cp2.movecs \
          output ferrocene_from_frag.movecs
  mult 1
end
driver
  maxiter 100
end
task dft optimize

