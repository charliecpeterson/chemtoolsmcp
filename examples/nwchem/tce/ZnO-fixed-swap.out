end

task scf energy

# Swap O 1s (MO 1, E=-20.49 h, centered on O) with Zn 3p (MO 5, E=-3.99 h, centered on Zn)
# so that MOs 1-4 are all Zn 3s/3p and MO 5 is O 1s.
# maxiter 0: skip SCF re-convergence so the swap is preserved in the output vectors.
# (Without maxiter 0, SCF re-converges to canonical energy ordering and puts O 1s back at MO 1.)
scf
  rhf
  maxiter 0
  print "final vectors analysis"
  vectors input zno.movecs swap 1 5 output zno-swap.movecs
end

task scf energy ignore

# After swap:  MO1=Zn3p  MO2=Zn3s  MO3=Zn3p  MO4=Zn3p  MO5=O1s  MO6-14=valence
# freeze 4 freezes MOs 1-4 (all Zn 3s/3p); O 1s at MO 5 enters the correlation space
tce
  freeze 4
  mp2
end

task tce energy

