start benzene
title "benzene opt+freq (B3LYP/6-31g*)"
echo

geometry units angstrom
  C  1.400000  0.000000  0.000000
  C  0.700000  1.212436  0.000000
  C  -0.700000  1.212436  0.000000
  C  -1.400000  0.000000  0.000000
  C  -0.700000  -1.212436  0.000000
  C  0.700000  -1.212436  0.000000
  H  2.480000  0.000000  0.000000
  H  1.240000  2.147743  0.000000
  H  -1.240000  2.147743  0.000000
  H  -2.480000  0.000000  0.000000
  H  -1.240000  -2.147743  0.000000
  H  1.240000  -2.147743  0.000000
end

charge 0

basis
  * library 6-31g*
end

dft
  xc b3lyp
  grid xfine
end

driver
  maxiter 200
end

task dft optimize
task dft freq
