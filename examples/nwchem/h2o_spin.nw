start h2o_spin
memory total 1000 mb

geometry units angstrom
  O 0.0000 0.0000 0.0000
  H 0.7572 0.5863 0.0000
  H -0.7572 0.5863 0.0000
end

basis; * library def2-tzvp; end

dft
  xc pbe0
  mult 1
  grid xfine
  vectors output dft.movecs
end

task dft optimize
task dft energy

dplot
  title "Spin density (will be ~0 for closed shell)"
  vectors dft.movecs
  gaussian
  spin spindens
  limitxyz
   -6.0  6.0  120
   -6.0  6.0  120
   -6.0  6.0  120
  output h2o_spindens.cube
end

task dplot

