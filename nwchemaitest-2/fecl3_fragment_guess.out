set tol2e 1e-8

set geometry fe_only
charge 3
dft
  xc b3lyp
  mult 6
  grid xfine
  direct
  iterations 200
  vectors input atomic output fe_only.movecs
end
task dft energy

set geometry cl3
charge -3
dft
  xc b3lyp
  mult 1
  grid xfine
  direct
  iterations 200
  vectors input atomic output cl3.movecs
end
task dft energy

set geometry full
charge 0
dft
  xc b3lyp
  mult 6
  grid xfine
  direct
  iterations 300
  convergence damp 50
  convergence ncydp 50
  smear 0.002
  mulliken
  vectors input fragment fe_only.movecs cl3.movecs \
          output fecl3_fragment_guess.movecs
end
task dft energy
