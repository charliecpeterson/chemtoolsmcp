    "stampede3_spr": {
      "description": "TACC Stampede3 SPR partition \u2014 560 nodes, 2\u00d756-core Intel Xeon CPU Max 9480 (Sapphire Rapids), 128 GB HBM2e.  Highest core count per node but lowest memory/core (1.1 GB/core).  Best for large jobs that are compute-bound, not memory-bound.  Charge rate: 2 SU/node-hr. NOTE: /opt/apps/python shadows system MKL \u2014 use LD_LIBRARY_PATH fix in pre_run if NWChem segfaults on SPR.\n",
      "launcher": {
        "kind": "scheduler",
        "submit_command": "sbatch",
        "scheduler_type": "slurm",
        "job_id_regex": "Submitted batch job (\\d+)",
