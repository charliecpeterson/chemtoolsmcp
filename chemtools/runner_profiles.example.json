        "status_command": "squeue -j {job_id} -h -o %T",
        "cancel_command": "scancel {job_id}"
      },
      "scheduler": {
        "system": "slurm",
        "script_template": "#!/bin/bash\n#SBATCH -J {job_name}\n#SBATCH -o {output_file}\n#SBATCH -e {error_file}\n#SBATCH -p {partition}\n#SBATCH -N {nodes}\n#SBATCH -n {mpi_ranks}\n#SBATCH -t {walltime}\n{account_line}\n{module_block}\ncd {job_dir}\n{pre_run_block}\n{mpi_launch} {nwchem_executable} {input_file}\n",
        "submit_script_name": "{job_name}.job"
