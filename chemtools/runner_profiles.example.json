      "execution": {
        "nwchem_executable": "/home1/01775/charlesp/apps/nwchem/7.2.3/bin/nwchem",
        "mpi_launch": "ibrun",
        "shell": "/bin/bash"
      },
      "resources": {
        "nodes": 1,
        "mpi_ranks": 48,
        "omp_threads": 1,
        "walltime": "24:00:00",
        "partition": "skx",
        "account": null,
        "account_command": "/usr/local/etc/taccinfo",
        "cores_per_node": 48,
        "node_memory_mb": 192000,
        "max_nodes": 256,
        "max_walltime": "48:00:00",
        "cpu_arch": "skx"
      },
      "modules": {
        "purge_first": false,
        "load": []
      },
      "env": {},
      "hooks": {
        "pre_run": []
      },
      "file_rules": {
        "output_file": "{job_name}.out",
        "error_file": "{job_name}.err",
        "restart_prefix": "{job_name}"
      }
