# TCE CCSD — freeze analysis
# Effective freeze count: 9 orbitals
# Per-element core orbital counts:
#   Fe (1 atoms): 9 all-e core/atom → 9=9 orbitals
# Proposed frozen MOs (from SCF output):
#   MO  10: E=   -0.5248 h  1 Fe (40%), d-like (40%)
#   MO  11: E=   -0.2531 h  1 Fe (37%), s-like (37%)
#   MO  12: E=   -0.1665 h  1 Fe (100%), d-like (100%)
#   MO  13: E=   -0.1567 h  1 Fe (41%), d-like (41%)
#   MO  14: E=   -0.1499 h  1 Fe (41%), d-like (41%)
#   MO  15: E=   -0.1148 h  1 Fe (41%), d-like (41%)

scf
  rohf
  nopen 4
  thresh 1e-8
  maxiter 200
  vectors input fe_atom_scf.movecs output fe_atom_ccsd.movecs
end

task scf energy

tce
  ccsd
  freeze 9
end

set tce:save_t T T

task tce energy
