# Restart from saved T amplitudes (iter 100, residual ~0.001).
# SCF already converged at -1411.672984 Eh. Use saved movecs.
# Trying thresh 1e-5 (much looser than default 1e-7) and DIIS 8
# Freeze: 11 (Fe=9, 2xO=2)

scf
  rohf
  nopen 1
  maxiter 200
  vectors input feo2_anion_ccsd_swap2.movecs output feo2_anion_ccsd_swap2.movecs
end

task scf energy

tce
  ccsd
  freeze 11
  maxiter 200
  thresh 1.0d-5
  diis 8
end

set tce:read_ta .true.
set tce:write_ta .true.

task tce energy
