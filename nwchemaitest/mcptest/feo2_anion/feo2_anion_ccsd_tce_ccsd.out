# TCE CCSD — freeze analysis
# Effective freeze count: 11 orbitals (corrected: 2 O atoms)
# Per-element core orbital counts:
#   Fe (1 atoms): 9 all-e core/atom → 9 orbitals
#   O (2 atoms): 1 all-e core/atom → 2 orbitals
# Proposed frozen MOs (from SCF output):
#   MO  17: E=   -0.5780 h  2 O (20%), 3 O (20%), p-like (40%)
#   MO  18: E=   -0.5003 h  1 Fe (57%), 2 O (22%), p-like (43%)
#   MO  19: E=   -0.3759 h  2 O (50%), 3 O (50%), p-like (100%)
#   MO  20: E=   -0.3759 h  2 O (50%), 3 O (50%), p-like (100%)
#   MO  21: E=    0.0803 h  1 Fe (43%), p-like (43%)
#   MO  22: E=    0.0805 h  1 Fe (42%), p-like (42%)

scf
  rohf
  nopen 1
  maxiter 200
  vectors output feo2_anion_ccsd.movecs
end

task scf energy

tce
  ccsd
  freeze 11
end

set tce:save_t T T

task tce energy
