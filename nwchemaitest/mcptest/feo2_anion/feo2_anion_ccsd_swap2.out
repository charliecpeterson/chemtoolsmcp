# TCE CCSD — aufbau correction step 2:
# Starting from feo2_anion_ccsd_swap.movecs (E=-1411.181 Eh) which has:
#   MO 21 (b2u, Fe 4py, +0.076 Eh): doubly occupied -- WRONG, too high
#   MO 22 (b2g, pi_g,   -0.212 Eh): SOMO -- correct
#   MO 23 (b3g, pi_g,   -0.026 Eh): virtual -- WRONG, lower than MO 21
# Swap 21<->23 to move b3g into doubly-occupied space and b2u to virtual.
# Freeze count: 11 (Fe=9, 2xO=2)

scf
  rohf
  nopen 1
  maxiter 200
  vectors input feo2_anion_ccsd_swap.movecs swap 21 23 output feo2_anion_ccsd_swap2.movecs
end

task scf energy

tce
  ccsd
  freeze 11
end

task tce energy
