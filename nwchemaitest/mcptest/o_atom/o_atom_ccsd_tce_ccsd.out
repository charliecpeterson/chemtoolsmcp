# TCE CCSD — freeze analysis
# Effective freeze count: 1 orbitals
# Per-element core orbital counts:
#   O (1 atoms): 1 all-e core/atom → 1=1 orbitals
# Proposed frozen MOs (from SCF output):
#   MO   2: E=   -1.2388 h  1 O (37%), s-like (37%)

scf
  rohf
  nopen 2
  thresh 1e-8
  maxiter 200
  vectors input o_atom_scf.movecs output o_atom_ccsd.movecs
end

task scf energy

tce
  ccsd
  freeze 1
end

set tce:save_t T T

task tce energy
