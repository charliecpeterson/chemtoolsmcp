                                                                                                                                               
  {                                                                                                                                            
    "schema_version": "1.0",                                                                                                                   
    "profiles": {
      "docker_mac": {                                                                                                                          
        "description": "NWChem 7.2.3 via Docker on macOS (linux/amd64 emulation, 1 MPI rank)",
        "launcher": {                                                                                                                          
          "kind": "direct",
          "command": "docker run --rm --platform linux/amd64 --entrypoint mpirun -v {job_dir}:/work -v /Users/charlie/test/mytest/nwchem-test/nwchem_basis_library:/basislib:ro -w /work -e NWCHEM_BASIS_LIBRARY=/basislib nwchem:7.2.3 -np 1 nwchem"
        },                                                                                                                                     
        "execution": {                                      
          "command_template": "{launcher} {input_file} > {output_file} 2> {error_file}",
          "working_directory": "{job_dir}",                                                                                                    
          "shell": "/bin/bash"
        },                                                                                                                                     
        "resources": {                                      
          "mpi_ranks": 1,
          "omp_threads": 1,                                                                                                                    
          "memory": null,
          "walltime": null                                                                                                                     
        },                                                  
        "env": {},
        "file_rules": {
          "output_file": "{job_name}.out",
          "error_file": "{job_name}.err",                                                                                                      
          "restart_prefix": "{job_name}"
        }                                                                                                                                      
      }                                                     
    }
  }

